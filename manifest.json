{
  "manifest_version": 3,
  "name": "OnePass Auth",
  "version": "1.0.0",
  "description": "TOTP authenticator – generate 6-digit codes (RFC 6238)",
  "icons": {
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.svg"
    }
  },
  "permissions": [
    "storage",
    "activeTab"
  ]
}
